# --- Osclass REST plugin (server-side only) ---
# Base URL of the Osclass REST API plugin. Example for the common
# "Rest API Plugin" build:
#   https://admin.listrex.com/index.php?page=api&action=v2
# Adjust to whatever your installed plugin documents (some builds use
# /api/v2 with friendly URLs enabled, others use the index.php query above).
OSCLASS_API_BASE_URL=

# Secret API key created in the Osclass admin > Plugins > Rest API > Settings.
# Use a READ key for the frontend's listing/search calls. Keep this secret —
# it is only ever read on the Next.js server, never sent to the browser.
OSCLASS_API_KEY=

# Optional: restrict listings to one category id (e.g. "Real Estate").
# Find the id in Osclass admin > Categories.
OSCLASS_DEFAULT_CATEGORY_ID=

# Optional: cap page size for /api/listings (max 50).
OSCLASS_PAGE_SIZE=24

# Optional: pin the URL convention used to talk to the Osclass REST plugin.
# Different REST plugins for Osclass use different URL shapes. By default the
# server probes a small list of known shapes on the first request, picks the
# one that returns valid JSON, and caches it. Set this to one of the ids
# below to skip auto-detection (useful in production once you know which one
# your install uses):
#   base           - <OSCLASS_API_BASE_URL>/items
#   rewrite-v3     - <origin>/api/v3/items   (Mindstellar-style rewrites)
#   rewrite-v2     - <origin>/api/v2/items
#   rewrite-v1     - <origin>/api/v1/items
#   indexphp-api   - <origin>/index.php?page=api&action=...
#   ajax-ocrest    - <origin>/index.php?page=ajax&action=oc-rest&route=...
OSCLASS_API_FLAVOR=auto

# Optional: when set to 1, /api/osclass/health and 502 responses from
# /api/listings* include upstream status + a short response-body excerpt to
# help diagnose connection or plugin-config issues. Never leaks the API key.
# Leave unset in normal production traffic.
OSCLASS_DEBUG=

# --- Public ---
# Optional public origin used for absolute URLs in OG/canonical metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
